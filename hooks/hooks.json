{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{
          "type": "command",
          "command": "node \"${extensionPath}${CLAUDE_PLUGIN_ROOT}/hooks/session-start.mjs\""
        }]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [{
          "type": "command",
          "command": "node \"${extensionPath}${CLAUDE_PLUGIN_ROOT}/hooks/recall.mjs\""
        }]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [{
          "type": "command",
          "command": "node \"${extensionPath}${CLAUDE_PLUGIN_ROOT}/hooks/remember.mjs\""
        }]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [{
          "type": "command",
          "command": "node \"${extensionPath}${CLAUDE_PLUGIN_ROOT}/hooks/session-end.mjs\""
        }]
      }
    ]
  }
}
