{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{
          "type": "command",
          "command": "node \"${extensionPath}/hooks/shared/session-start.mjs\""
        }]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [{
          "type": "command",
          "command": "node \"${extensionPath}/hooks/shared/recall.mjs\""
        }]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [{
          "type": "command",
          "command": "node \"${extensionPath}/hooks/shared/remember.mjs\""
        }]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [{
          "type": "command",
          "command": "node \"${extensionPath}/hooks/shared/session-end.mjs\""
        }]
      }
    ]
  }
}
