      "Bash(git restore *)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git branch -D*)",
      "Bash(git cherry-pick*)",
      "Bash(rm -rf*)",
      "Bash(rm -r *)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(pnpm update-locks*)",
      "Bash(terraform apply*)",
      "Bash(./tf apply*)",
      "Bash(kubectl delete*)",
      "Bash(kubectl edit*)",
      "Bash(scripts/pipeline/stage-8-deploy*)",
      "Bash(miri*sync*)",
