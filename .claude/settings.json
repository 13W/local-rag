      "Bash(pnpm exec biome:*)",
      "Bash(pnpm biome:*)",
      "Bash(pnpm run check:types:*)",
      "Bash(pnpm knip:fix:*)",
      "Bash(pnpm knip:check:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
